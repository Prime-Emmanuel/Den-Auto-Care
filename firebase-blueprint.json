{
  "collections": [
    {
      "name": "products",
      "fields": [
        { "name": "name", "type": "string" },
        { "name": "price", "type": "string" },
        { "name": "image", "type": "string" },
        { "name": "desc", "type": "string" }
      ],
      "rules": [
        {
          "allow": "read",
          "condition": "true"
        },
        {
          "allow": "write",
          "condition": "request.auth != null && request.auth.token.email == 'malongueprime@gmail.com'"
        }
      ]
    }
  ]
}
